# Server Configuration
PORT=5000
NODE_ENV=development

# Database — replace with your MongoDB Atlas connection string
MONGODB_URI=mongodb://localhost:27017/decode_it

# JWT — use a long random string (min 32 chars)
JWT_SECRET=REPLACE_WITH_YOUR_SECRET_KEY_MIN_32_CHARS

# Gemini API — get from https://aistudio.google.com
GEMINI_API_KEY=REPLACE_WITH_YOUR_GEMINI_API_KEY
